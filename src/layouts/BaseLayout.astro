---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  lang?: "en" | "es";
  /** Extra JSON-LD blocks (e.g. FAQPage, ItemList) rendered in <head>. */
  jsonLd?: Record<string, unknown>[];
}

const {
  title = "Vaneco — Natural Stone Workshop",
  description = "Custom granite and marble countertops, designed for your space and installed with precision. Serving Tijuana, Rosarito, and Tecate.",
  image = "/og-image.jpg",
  lang = "en",
  jsonLd = [],
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;

// Global LocalBusiness schema — home of Vaneco's NAP + service area (spec 7c).
const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Piedras Vaneco",
  description:
    "Taller de cubiertas de piedra natural — granito, cuarzo, cuarcita, mármol y ónix.",
  email: "contacto@piedrasvaneco.com",
  telephone: "+526648081307",
  url: "https://pvane.co",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Tijuana",
    addressRegion: "B.C.",
    addressCountry: "MX",
  },
  areaServed: ["Tijuana", "Playas de Rosarito", "Tecate", "Ensenada"],
  foundingDate: "2016",
};

const schemas = [localBusiness, ...jsonLd];
---

<!doctype html>
<html lang={lang} class="dark">
  <head>
    <!-- Meta -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content={lang === "es" ? "es_MX" : "en_US"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Structured data (JSON-LD) -->
    {
      schemas.map((s) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(s)}
        />
      ))
    }

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Theme script — runs before render to avoid flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("vaneco-theme");

        // Dark is the product default. A stored choice always wins; with no
        // stored choice we stay dark (design is dark-first).
        const isDark = stored !== "light";

        const html = document.documentElement;
        if (isDark) {
          html.classList.remove("light");
          html.classList.add("dark");
        } else {
          html.classList.remove("dark");
          html.classList.add("light");
        }
      })();
    </script>
  </head>

  <body>
    <slot />

    <!-- Theme sync script — keeps localStorage in sync -->
    <script>
      // Listen for theme changes dispatched by ThemeToggle component
      window.addEventListener("vaneco:theme-change", (e: Event) => {
        const { theme } = (e as CustomEvent).detail;
        const html = document.documentElement;
        html.classList.toggle("dark", theme === "dark");
        html.classList.toggle("light", theme === "light");
        localStorage.setItem("vaneco-theme", theme);
      });
    </script>
  </body>
</html>
