---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Navbar, MobileTopBar } from "../components/ui/Navbar";
import { FloatingBottomNav } from "../components/ui/FloatingBottomNav";
import { Home } from "../components/home/Home";
---

<BaseLayout
  title="Vaneco — Cubiertas de piedra natural en Tijuana"
  description="Diseñamos, fabricamos e instalamos cubiertas de piedra natural. De la visita a la instalación, sin intermediarios. Tijuana, B.C."
  lang="es"
>
  <Navbar currentPath="/" client:load />
  <MobileTopBar client:load />
  <main>
    <Home client:load />
  </main>
  <FloatingBottomNav currentPath="/" client:load />
</BaseLayout>
